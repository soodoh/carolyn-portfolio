    "@types/bcryptjs": "^3.0.0",
    "@types/node": "25.3.3",
    "@types/react": "^19.2.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxlint": "^1.51.0",
    "postcss": "^8.5.8",

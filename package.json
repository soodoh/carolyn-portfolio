{
	"name": "carolyn-portfolio",
	"version": "0.2.0",
	"homepage": "https://carolyndiloreto.com",
	"private": true,
	"type": "module",
	"author": "Paul DiLoreto <soodohh@pm.me>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/soodoh/carolyn-portfolio/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/soodoh/carolyn-portfolio.git"
	},
	"keywords": [
		"tanstack-start",
		"contentful",
		"react",
		"serverless"
	],
	"packageManager": "bun@1.2.4",
	"scripts": {
		"prebuild": "bun run scripts/generate-auth-manifest.ts",
		"predev": "bun run scripts/generate-auth-manifest.ts",
		"dev": "vite dev",
		"build": "vite build && bun run scripts/clean-production-artifact.ts",
		"build:test": "PLAYWRIGHT_TEST=true PROJECT_AUTH_SECRET=playwright-secret bun run build",
		"typecheck": "bun run build:test && tsc --noEmit",
		"validate": "bun run lint && bun run test:unit && bun run typecheck && bun run verify:prerender",
		"verify:prerender": "bun run scripts/verify-prerender-output.ts",
		"lint": "biome check .",
		"test:unit": "bun test ./tests/unit/*.unit.ts",
		"lint:fix": "biome check --write .",
		"test:amplify": "./scripts/playwright-docker.sh --config=playwright.amplify.config.ts",
		"test:visual": "./scripts/playwright-docker.sh",
		"test:visual:update": "./scripts/playwright-docker.sh --update-snapshots=all",
		"prepare": "[ \"$PLAYWRIGHT_CONTAINER\" = \"true\" ] || lefthook install"
	},
	"dependencies": {
		"@aws-sdk/client-ssm": "3.1090.0",
		"@contentful/rich-text-from-markdown": "^16.2.1",
		"@contentful/rich-text-react-renderer": "^16.2.1",
		"@tanstack/react-router": "^1.170.17",
		"@tanstack/react-start": "^1.168.27",
		"@unpic/react": "^1.0.2",
		"bcryptjs": "^3.0.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"contentful": "^11.12.7",
		"embla-carousel-react": "^8.6.0",
		"lucide-react": "^1.24.0",
		"p-all": "^5.0.1",
		"radix-ui": "^1.6.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-masonry-css": "^1.0.16",
		"sharp": "^0.35.3",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@commitlint/types": "^21.2.0",
		"@contentful/rich-text-types": "^17.2.7",
		"@playwright/test": "1.61.1",
		"@tailwindcss/vite": "^4.3.2",
		"@types/bun": "1.2.4",
		"@types/node": "26.1.1",
		"@types/react": "^19.2.17",
		"@vitejs/plugin-react": "^6.0.3",
		"lefthook": "^2.1.10",
		"nitro": "3.0.260610-beta",
		"shadcn": "^4.13.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "5.9.3",
		"vite": "^8.1.4"
	},
	"trustedDependencies": [
		"unrs-resolver"
	]
}
